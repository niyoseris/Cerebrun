modules = ["rust-stable", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["openssl"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MCP Server"

[[workflows.workflow]]
name = "MCP Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cargo run"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["./target/release/user-context-mcp"]
build = ["cargo", "build", "--release"]

[userenv]

[userenv.shared]

[userenv.development]
GOOGLE_REDIRECT_URI = "https://18f35d8f-bfce-403e-9f66-d910b0d39a14-00-38my8z0fk4olj.kirk.replit.dev/auth/google/callback"

[userenv.production]
GOOGLE_REDIRECT_URI = "https://cerebrun.replit.app/auth/google/callback"
